rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users Collection
    match /users/{userId} {
      allow read, write: if true; // Replace with auth check after adding login
    }

    // Sessions Collection
    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if true; // Replace with admin check after adding login
    }

    // Attendance Collection
    match /attendance/{attendanceId} {
      allow read, write: if true; // Replace with auth check after adding login
    }

    // Billing Collection
    match /billing/{billId} {
      allow read, write: if true; // Replace with auth check after adding login
    }
  }
}
